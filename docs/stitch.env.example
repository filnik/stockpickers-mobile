# Copy to `stitch.env` (git-ignored) and fill in with your own identifiers.
#   cp docs/stitch.env.example docs/stitch.env
#
# STITCH_QUOTA_PROJECT — the GCP project billed for the Stitch API. It is the same
# id you pass to `gcloud auth application-default set-quota-project`.
# STITCH_PROJECT_ID   — the Stitch project (a container of screens). Create one with
# the `create_project` tool; see stitch-api.md.

STITCH_QUOTA_PROJECT=your-gcp-project-id
STITCH_PROJECT_ID=your-stitch-project-id
