# project.yml is the source of truth; the .xcodeproj is generated from it:
#     brew install xcodegen && cd iosApp && xcodegen generate
# Tracking the pbxproj would mean resolving its merge conflicts by hand.
*.xcodeproj/
*.xcworkspace/

# Generated by xcodegen from the `info:` block in project.yml.
iosApp/Info.plist

# Xcode
xcuserdata/
*.xcuserstate
DerivedData/
build/
.DS_Store
